generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEAM
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ProposalType {
  PROGRAM_IDEA
  REFERRAL
  SPONSOR_SUGGESTION
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProgramCategory {
  MUSICA
  ENTRETENIMIENTO
  CIUDADANO
  BIENESTAR
  RETRO
  CULTURAL
}

model User {
  id        String     @id @default(cuid())
  nombre    String
  apellido  String
  username  String     @unique
  email     String     @unique
  password  String
  telefono  String?
  direccion String?
  role      Role       @default(TEAM)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  proposals Proposal[]
}

model Program {
  id            String          @id @default(cuid())
  titulo        String
  descripcion   String
  conductor     String
  horarioInicio String
  horarioFin    String
  dias          String[]
  categoria     ProgramCategory
  activo        Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Sponsor {
  id          String   @id @default(cuid())
  empresa     String
  contacto    String
  email       String?
  telefono    String?
  descripcion String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Proposal {
  id        String         @id @default(cuid())
  tipo      ProposalType
  status    ProposalStatus @default(PENDING)
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  adminNota String?

  // PROGRAM_IDEA
  progTitulo      String?
  progDescripcion String?
  progHorario     String?
  progDias        String?
  progConductor   String?

  // REFERRAL
  refNombre   String?
  refEmail    String?
  refTelefono String?
  refNota     String?

  // SPONSOR_SUGGESTION
  sponEmpresa  String?
  sponContacto String?
  sponEmail    String?
  sponNota     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
